# ============================================================================
# VIRALytics environment matrix
# Copy to .env.local (web) and .env (worker). Never commit real secrets.
# Column "Where": V = Vercel (web), R = Railway (worker), B = both
# ============================================================================

# --- Supabase --------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=            # [V] https://<ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=       # [V] public anon key (safe with RLS)
SUPABASE_SERVICE_ROLE_KEY=           # [B] server-only, bypasses RLS — guard carefully

# --- Encryption (OAuth token storage) --------------------------------------
ENCRYPTION_KEY=                      # [B] 64-char hex (32 bytes). Generate: openssl rand -hex 32

# --- Upstash Redis (cache + BullMQ + rate limit) ---------------------------
UPSTASH_REDIS_REST_URL=              # [B] REST URL (cache + ratelimit)
UPSTASH_REDIS_REST_TOKEN=           # [B] REST token
REDIS_URL=                           # [R] rediss:// connection string for BullMQ (ioredis)

# --- Scraping / public APIs ------------------------------------------------
APIFY_API_TOKEN=                     # [R] worker only — never expose to browser
YOUTUBE_API_KEY=                     # [R] YouTube Data API v3 key (public data)

# --- OAuth (private metrics, Phase 7) --------------------------------------
YOUTUBE_CLIENT_ID=                   # [B] YouTube Analytics OAuth
YOUTUBE_CLIENT_SECRET=               # [B]
META_APP_ID=                         # [B] Instagram Graph OAuth
META_APP_SECRET=                     # [B]
TIKTOK_CLIENT_KEY=                   # [B]
TIKTOK_CLIENT_SECRET=                # [B]

# --- Stripe ----------------------------------------------------------------
STRIPE_SECRET_KEY=                   # [V] server only
STRIPE_WEBHOOK_SECRET=               # [V] webhook signature verification

# --- App / monitoring ------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000   # [V] used for OAuth redirects + Stripe return URLs
SENTRY_DSN=                          # [B] error monitoring
